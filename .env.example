# JWT (minimum 32 characters)
JWT_SECRET=fixlink-super-secret-jwt-key-minimum-32chars-long

# LiveKit (defaults work with --dev mode)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret123456789012345678901

# Groq (optional — mock summary used if empty)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# Frontend
VITE_API_URL=http://localhost:8080/api
VITE_LIVEKIT_URL=ws://localhost:7880
